<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <!-- バージョンは 1.0.0 固定、アンインストール/アップグレード用UpgradeCodeを設定 -->
    <Product Id="*" Name="Easy-File-Size" Language="1033" Version="1.0.0" Manufacturer="YuzukoUnderson" UpgradeCode="7ea589d8-963c-45a8-bd2f-f6d2f3b92789">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <!-- インストール機能の定義 -->
        <Feature Id="ProductFeature" Title="Easy-File-Size" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="EnvPath" />
        </Feature>
    </Product>

    <!-- インストール先ディレクトリ構造の定義 -->
    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="Easy-File-Size" />
            </Directory>
        </Directory>
    </Fragment>

    <!-- コンポーネント定義 -->
    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <!-- Sourceはpkgで出力されたexe。インストール先ではyoryo.exeにリネームして配置 -->
            <Component Id="ProductComponent" Guid="3fcd7b9b-c40d-4bd9-93e3-774fbe8cb14d">
                <File Id="YoryoExe" Source="dist\easy-file-size-win.exe" Name="yoryo.exe" KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <!-- システム環境変数 PATH にインストールフォルダを追加するコンポーネント -->
        <DirectoryRef Id="INSTALLFOLDER">
            <Component Id="EnvPath" Guid="f7f8fe3d-a40d-4fd9-bd2f-f6d2f3b92789">
                <CreateFolder />
                <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
            </Component>
        </DirectoryRef>
    </Fragment>
</Wix>
